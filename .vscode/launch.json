{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "ScaleBook (Debug)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--dart-define-from-file",
        "config/api-keys.json"
      ]
    },
    {
      "name": "ScaleBook (Profile)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "profile",
      "args": [
        "--dart-define-from-file",
        "config/api-keys.json"
      ]
    },
    {
      "name": "ScaleBook (Release)",
      "request": "launch",
      "type": "dart",
      "flutterMode": "release",
      "args": [
        "--dart-define-from-file",
        "config/api-keys.json"
      ]
    }
  ]
}
